{
  "manifest_version": 3,
  "name": "Scar",
  "version": "1.0.0",
  "description": "Extract media from HTML, TSX, CSS, and JSON.",
  "homepage_url": "https://github.com/setjet/scar",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Scar",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "scar@local",
      "strict_min_version": "109.0"
    }
  }
}
