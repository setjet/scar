{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node", "chrome"],
    "resolveJsonModule": true
  },
  "include": ["png-extractor-extension/src/**/*.ts", "tests/**/*.ts"]
}

